# Ignore local Terraform directories
**/.terraform/*

# State files
*.tfstate
*.tfstate.*
.terraform.lock.hcl

# Crash log
crash.log

# CLI configuration
.terraformrc
terraform.rc

# Override and local var files
override.tf
override.tf.json
*.tfvars
*.tfvars.json

# Terraform plan outputs
*.tfplan

# Backup files
*.backup

# Editor and system files
.vscode/
.idea/
*.swp
*.swo
*.DS_Store

# Logs
*.log

# Archives and binaries (common large file types)
*.zip
*.tar.gz
*.tar
*.rar
*.7z
*.iso
*.exe
*.dll
*.so
*.bin

# Images and media (often large)
*.jpg
*.jpeg
*.png
*.gif
*.mp4
*.mov

# Node/Python folders
node_modules/
__pycache__/
*.pyc
